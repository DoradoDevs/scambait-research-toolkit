# =============================================================================
# Scambait Research Toolkit - Example environment configuration
# =============================================================================
# Copy this file to `.env` and adjust as needed:
#   cp .env.example .env
#
# This project ships with NO secrets and makes NO outbound network calls.
# Every value below is optional and has a safe built-in default.
# `.env` is gitignored so your local settings never get committed.

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
# Port for the local dashboard. The host is hardcoded to 127.0.0.1 in config.py
# on purpose and cannot be changed via the environment - keep it localhost-only.
SCAMBAIT_PORT=8000

# -----------------------------------------------------------------------------
# Wallet honeypot (fake crypto display - NO REAL FUNDS)
# -----------------------------------------------------------------------------
# Public display address for the fake wallet page. The default is the Solana
# "incinerator" burn address, which nobody controls. NEVER put an address you
# actually own here - this page is shown to scammers.
HONEYPOT_ADDRESS=1nc1nerator11111111111111111111111111111111

# Fake balance numbers shown on the honeypot page.
HONEYPOT_BALANCE_SOL=47832.91
HONEYPOT_BALANCE_USD=4783291.00
